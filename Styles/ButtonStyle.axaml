    <Style Selector="Button.rounded.teal:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFA0E0E8" Offset="0"/>
                <GradientStop Color="#FF20A0A0" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.teal:pressed /template/ ContentPresenter#PART_ContentPresenter">
