                <GradientStop Color="#FFA0522D" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#7B3F1E"/>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    
    <Style Selector="Button.rounded.brown:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
