                <GradientStop Color="#FFB8683D" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.brown:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFA0522D" Offset="0"/>
                <GradientStop Color="#FF7B3F1E" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Cyan Button -->
    <Style Selector="Button.rounded.cyan">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFB2FFFF" Offset="0"/>
                <GradientStop Color="#FF00CED1" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#008B8B"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button.rounded.cyan:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFD0FFFF" Offset="0"/>
                <GradientStop Color="#FF20E0E3" Offset="1"/>
            </LinearGradientBrush>
