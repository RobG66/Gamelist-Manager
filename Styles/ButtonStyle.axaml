    <!-- Placeholder for additional styles -->
    
    <!-- Nav Toggle (hamburger) -->
    <Style Selector="ToggleButton.nav-toggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style Selector="ToggleButton.nav-toggle:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
    </Style>
    <Style Selector="ToggleButton.nav-toggle:checked /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
    </Style>
    <Style Selector="ToggleButton.nav-toggle:disabled">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Opacity" Value="0.5"/>
    </Style>

    <!-- Menu Button (for navigation/toolbar buttons with transparent disabled state) -->
    <Style Selector="Button.MenuButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="8,6"/>
        <Setter Property="Margin" Value="2"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Foreground" Value="{DynamicResource NavButtonForeground}"/>
    </Style>
    <Style Selector="Button.MenuButton:pointerover /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonHoverBrush}"/>
    </Style>
    <Style Selector="Button.MenuButton:pressed /template/ ContentPresenter">
        <Setter Property="Background" Value="{DynamicResource ButtonPressedBrush}"/>
    </Style>
    <Style Selector="Button.MenuButton:disabled">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Opacity" Value="0.5"/>
    </Style>
    <Style Selector="Button.MenuButton:disabled /template/ ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Media Viewer Button -->
    <Style Selector="Button.rounded.media">
        <Setter Property="BorderBrush" Value="#9C27B0"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFDDA0DD" Offset="0"/>
                <GradientStop Color="#FF9C27B0" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.rounded.media:pointerover /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFE8B5E8" Offset="0"/>
                <GradientStop Color="#FFAB47BC" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    <Style Selector="Button.rounded.media:pressed /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF9C27B0" Offset="0"/>
                <GradientStop Color="#FF7B1FA2" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Scraper Button -->
    <Style Selector="Button.rounded.scraper">
        <Setter Property="BorderBrush" Value="#FF6F00"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFFD580" Offset="0"/>
                <GradientStop Color="#FFFF6F00" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="Foreground" Value="White"/>
    </Style>
    <Style Selector="Button.rounded.scraper:pointerover /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFFE0A0" Offset="0"/>
                <GradientStop Color="#FFFF8F00" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    <Style Selector="Button.rounded.scraper:pressed /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFFF6F00" Offset="0"/>
                <GradientStop Color="#FFE65100" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Edit Mode Toggle -->
    <Style Selector="ToggleButton.edit-toggle">
        <Setter Property="BorderBrush" Value="#9E9E9E"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFE0E0E0" Offset="0"/>
                <GradientStop Color="#FF9E9E9E" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.edit-toggle:pointerover /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFE8E8E8" Offset="0"/>
                <GradientStop Color="#FFB0B0B0" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.edit-toggle:checked">
        <Setter Property="BorderBrush" Value="#2196F3"/>
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF90CAF9" Offset="0"/>
                <GradientStop Color="#FF2196F3" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.edit-toggle:checked:pointerover /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FFA5D6FA" Offset="0"/>
                <GradientStop Color="#FF42A5F5" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.edit-toggle:checked:pressed /template/ ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                <GradientStop Color="#FF2196F3" Offset="0"/>
                <GradientStop Color="#FF1976D2" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Pill Button — fully rounded, compact, fits inside a status bar without growing its height -->
    <Style Selector="Button.pill">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{DynamicResource GlobalSmallFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="8,1"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="ToolTip.Placement" Value="Bottom"/>
        <Setter Property="ToolTip.VerticalOffset" Value="6"/>
    </Style>

    <Style Selector="Button.pill /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="8,1"/>
    </Style>

</Styles>
