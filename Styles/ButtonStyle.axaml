<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Base Rounded Button Theme (25% smaller than default) -->
    <Style Selector="Button.rounded">
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{DynamicResource GlobalSmallFontSize}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="MinWidth" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="4,2"/>
        <Setter Property="ToolTip.Placement" Value="Bottom"/>
        <Setter Property="ToolTip.VerticalOffset" Value="6"/>
    </Style>

    <Style Selector="Button.rounded /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Padding" Value="4,2"/>
    </Style>

    <!-- Green Button -->
    <Style Selector="Button.rounded.green">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FF98FB98" Offset="0"/>
                <GradientStop Color="#FF66C266" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#66C266"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button.rounded.green:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFB0FFB0" Offset="0"/>
                <GradientStop Color="#FF7FD47F" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.green:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FF66C266" Offset="0"/>
                <GradientStop Color="#FF4CAF50" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Red Button -->
    <Style Selector="Button.rounded.red">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFFFA07A" Offset="0"/>
                <GradientStop Color="#FFCD5C5C" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#CD5C5C"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button.rounded.red:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFFFC0A0" Offset="0"/>
                <GradientStop Color="#FFE57373" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.red:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFCD5C5C" Offset="0"/>
                <GradientStop Color="#FFB71C1C" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Blue Button -->
    <Style Selector="Button.rounded.blue">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FF87CEFA" Offset="0"/>
