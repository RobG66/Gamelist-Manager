    <!-- Pink Button -->
    <Style Selector="Button.rounded.pink">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFFFB6C1" Offset="0"/>
                <GradientStop Color="#FFDB7093" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#AA4B6E"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button.rounded.pink:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFFFD0D8" Offset="0"/>
                <GradientStop Color="#FFEF90B0" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.pink:pressed /template/ ContentPresenter#PART_ContentPresenter">
