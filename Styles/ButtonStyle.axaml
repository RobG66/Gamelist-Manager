            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#4682B4"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button.rounded.blue:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFA0D8FF" Offset="0"/>
                <GradientStop Color="#FF5A9BD4" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.blue:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
