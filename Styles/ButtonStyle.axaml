                <GradientStop Color="#FFAA44DD" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.purple:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
