                <GradientStop Color="#FF008B8B" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>

    <!-- Lime Button -->
    <Style Selector="Button.rounded.lime">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFCCFF99" Offset="0"/>
                <GradientStop Color="#FF99CC00" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
        <Setter Property="BorderBrush" Value="#669900"/>
        <Setter Property="Foreground" Value="Black"/>
    </Style>
    
    <Style Selector="Button.rounded.lime:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                <GradientStop Color="#FFDDFFAA" Offset="0"/>
                <GradientStop Color="#FFAADD20" Offset="1"/>
            </LinearGradientBrush>
        </Setter>
    </Style>
    
    <Style Selector="Button.rounded.lime:pressed /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background">
            <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
