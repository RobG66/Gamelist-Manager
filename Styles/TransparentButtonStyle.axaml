<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Transparent/chrome-free button - shows only its content (e.g. an image) -->
    <!-- Transitions live on the Button itself so pseudo-class changes animate reliably -->
    <Style Selector="Button.icon">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Opacity" Value="0.75"/>
        <Setter Property="ToolTip.Placement" Value="Bottom"/>
        <Setter Property="ToolTip.VerticalOffset" Value="4"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform" Value="scale(1)"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.15"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter Content="{TemplateBinding Content}"
                                  HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Padding="{TemplateBinding Padding}"/>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="Button.icon:not(:disabled):pointerover">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="RenderTransform" Value="scale(1.05)"/>
    </Style>

    <Style Selector="Button.icon:not(:disabled):pressed">
        <Setter Property="Opacity" Value="1"/>
        <Setter Property="RenderTransform" Value="scale(0.95)"/>
    </Style>

    <Style Selector="Button.icon:disabled">
        <Setter Property="Opacity" Value="0.3"/>
        <Setter Property="Cursor" Value="Arrow"/>
    </Style>

</Styles>
