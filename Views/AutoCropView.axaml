<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="740" d:DesignHeight="480"
        x:Class="Gamelist_Manager.Views.AutoCropView"
        Title="Auto Crop"
        Width="740"
        Height="480"
        MinWidth="500"
        MinHeight="340"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        FontSize="{DynamicResource GlobalFontSize}">

    <Grid RowDefinitions="*,Auto,Auto,Auto,Auto" Margin="12">

        <!-- Side-by-side image panels -->
        <Grid Grid.Row="0" ColumnDefinitions="*,8,*">

            <!-- Original image -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Original"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid Grid.Row="1">
                    <Border x:Name="OriginalImageBorder"
                            CornerRadius="4"
                            ClipToBounds="True"/>
                    <Viewbox Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Border BorderThickness="2"
                                BorderBrush="{DynamicResource SecondaryTextBrush}">
                            <Image x:Name="OriginalImage"/>
                        </Border>
                    </Viewbox>
                </Grid>
            </Grid>

            <!-- Preview image -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Cropped"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid Grid.Row="1">
                    <Border x:Name="PreviewImageBorder"
                            CornerRadius="4"
                            ClipToBounds="True"/>
                    <Viewbox Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Border BorderThickness="2"
                                BorderBrush="{DynamicResource SecondaryTextBrush}">
                            <Image x:Name="PreviewImage"/>
                        </Border>
                    </Viewbox>
                </Grid>
            </Grid>

        </Grid>

        <!-- Dimension info -->
        <TextBlock Grid.Row="1"
                   x:Name="DimensionText"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,4"
                   Foreground="{DynamicResource SecondaryTextBrush}"/>

        <!-- Padding slider -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*,Auto"
              Margin="0,0,0,8">
            <TextBlock Grid.Column="0"
                       Text="Padding"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <Slider Grid.Column="1"
                    x:Name="PaddingSlider"
                    Minimum="0"
                    Maximum="50"
                    Value="0"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       x:Name="PaddingValueText"
                       Text="0%"
                       VerticalAlignment="Center"
                       MinWidth="32"
                       TextAlignment="Right"
                       Margin="8,0,0,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
        </Grid>

        <!-- Maintain aspect ratio -->
        <CheckBox Grid.Row="3"
                  x:Name="MaintainAspectRatioCheckBox"
                  Content="Crop all empty space"
                  IsChecked="False"
                  Margin="0,0,0,8"
                  Foreground="{DynamicResource PrimaryTextBrush}"/>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button x:Name="DiscardButton"
                    Content="Discard"
                    Classes="rounded grey"
                    FontSize="{DynamicResource GlobalFontSize}"
                    Click="DiscardButton_Click"/>
            <Button x:Name="KeepButton"
                    Content="Keep"
                    Classes="rounded green"
                    FontSize="{DynamicResource GlobalFontSize}"
                    Click="KeepButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
