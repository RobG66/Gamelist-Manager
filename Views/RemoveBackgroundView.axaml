<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="740" d:DesignHeight="520"
        x:Class="Gamelist_Manager.Views.RemoveBackgroundView"
        Title="Remove Background"
        Width="740"
        Height="520"
        MinWidth="500"
        MinHeight="380"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        FontSize="{DynamicResource GlobalFontSize}">

    <Grid RowDefinitions="*,Auto,Auto,Auto" Margin="12">

        <!-- Side-by-side image panels -->
        <Grid Grid.Row="0" ColumnDefinitions="*,8,*">

            <!-- Original image -->
            <Grid Grid.Column="0" RowDefinitions="Auto,*">
                <TextBlock Grid.Row="0"
                           Text="Original"
                           HorizontalAlignment="Center"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"
                           Foreground="{DynamicResource PrimaryTextBrush}"/>
                <Grid Grid.Row="1">
                    <Border x:Name="OriginalImageBorder"
                            CornerRadius="4"
                            ClipToBounds="True"/>
                    <Viewbox Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Border BorderThickness="2"
                                BorderBrush="{DynamicResource SecondaryTextBrush}">
                            <Image x:Name="OriginalImage"
                                   Stretch="Uniform"/>
                        </Border>
                    </Viewbox>
                </Grid>
            </Grid>

            <!-- Preview image (checkerboard background set in code-behind) -->
            <Grid Grid.Column="2" RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,4">
                    <TextBlock Text="Preview"
                               HorizontalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock Grid.Column="1"
                               x:Name="StrategyText"
                               FontStyle="Italic"
                               VerticalAlignment="Center"
                               Margin="8,0,0,0"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                </Grid>
                <Grid Grid.Row="1">
                    <Border x:Name="PreviewImageBorder"
                            CornerRadius="4"
                            ClipToBounds="True"/>
                    <Viewbox Stretch="Uniform"
                             HorizontalAlignment="Center"
                             VerticalAlignment="Center">
                        <Border BorderThickness="2"
                                BorderBrush="{DynamicResource SecondaryTextBrush}">
                            <Image x:Name="PreviewImage"
                                   Stretch="Uniform"/>
                        </Border>
                    </Viewbox>
                    <Border x:Name="BusyOverlay"
                            Background="#80000000"
                            CornerRadius="4"
                            IsVisible="True">
                        <ProgressBar IsIndeterminate="True"
                                     Width="160"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Grid>

        </Grid>

        <!-- Mode selector -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,Auto,Auto,Auto"
              Margin="0,10,0,0">
            <TextBlock Grid.Column="0"
                       Text="Mode"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <ComboBox Grid.Column="1"
                      x:Name="ModeComboBox"
                      SelectedIndex="0"
                      FontSize="{DynamicResource GlobalFontSize}">
                <ComboBoxItem>Automatic</ComboBoxItem>
                <ComboBoxItem>Circle</ComboBoxItem>
                <ComboBoxItem>Freeform</ComboBoxItem>
                <ComboBoxItem>Outline</ComboBoxItem>
            </ComboBox>
            <CheckBox Grid.Column="2"
                      x:Name="RemoveEnclosedCheckBox"
                      Content="Remove enclosed regions"
                      Margin="16,0,0,0"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource PrimaryTextBrush}"/>
            <CheckBox Grid.Column="3"
                      x:Name="InvertCheckBox"
                      Content="Invert colors"
                      Margin="16,0,0,0"
                      VerticalAlignment="Center"
                      Foreground="{DynamicResource PrimaryTextBrush}"/>
        </Grid>

        <!-- Tolerance slider -->
        <Grid Grid.Row="2"
              ColumnDefinitions="Auto,*,Auto"
              Margin="0,10,0,10">
            <TextBlock Grid.Column="0"
                       Text="Tolerance"
                       VerticalAlignment="Center"
                       Margin="0,0,8,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <Slider Grid.Column="1"
                    x:Name="ToleranceSlider"
                    Minimum="0"
                    Maximum="50"
                    Value="20"
                    VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                       x:Name="ToleranceValueText"
                       Text="20"
                       VerticalAlignment="Center"
                       MinWidth="24"
                       TextAlignment="Right"
                       Margin="8,0,0,0"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="8">
            <Button x:Name="DiscardButton"
                    Content="Discard"
                    Classes="rounded grey"
                    FontSize="{DynamicResource GlobalFontSize}"
                    Click="DiscardButton_Click"/>
            <Button x:Name="KeepButton"
                    Content="Keep"
                    Classes="rounded green"
                    IsEnabled="False"
                    FontSize="{DynamicResource GlobalFontSize}"
                    Click="KeepButton_Click"/>
        </StackPanel>

    </Grid>
</Window>
