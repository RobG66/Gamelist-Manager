<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d" d:DesignWidth="450" d:DesignHeight="200"
    x:Class="Gamelist_Manager.Views.ThreeButtonDialogView"
    Title="Confirm"
    MinWidth="450"
    SizeToContent="WidthAndHeight"
    FontSize="{DynamicResource GlobalFontSize}"
    WindowStartupLocation="CenterOwner"
    CanResize="False">
    
    <Window.Resources>
        <!-- Question/Info Theme (Blue/Cyan) -->
        <SolidColorBrush x:Key="QuestionBackgroundLight" Color="#D1ECF1"/>
        <SolidColorBrush x:Key="QuestionForegroundLight" Color="#0C5460"/>
        <SolidColorBrush x:Key="QuestionBackgroundDark" Color="#055160"/>
        <SolidColorBrush x:Key="QuestionForegroundDark" Color="#B6EFFB"/>
        
        <!-- Warning Theme (Yellow/Orange) -->
        <SolidColorBrush x:Key="WarningBackgroundLight" Color="#FFF3CD"/>
        <SolidColorBrush x:Key="WarningForegroundLight" Color="#856404"/>
        <SolidColorBrush x:Key="WarningBackgroundDark" Color="#664D03"/>
        <SolidColorBrush x:Key="WarningForegroundDark" Color="#FFECB5"/>
    </Window.Resources>
    
    <Window.Styles>
        <!-- Question/Info Icon Styles -->
        <Style Selector="Window[RequestedThemeVariant=Light] Border.question-icon, Window[RequestedThemeVariant=Light] Border.info-icon">
            <Setter Property="Background" Value="{StaticResource QuestionBackgroundLight}"/>
        </Style>
        <Style Selector="Window[RequestedThemeVariant=Light] TextBlock.question-icon, Window[RequestedThemeVariant=Light] TextBlock.info-icon">
            <Setter Property="Foreground" Value="{StaticResource QuestionForegroundLight}"/>
        </Style>
        <Style Selector="Window[RequestedThemeVariant=Dark] Border.question-icon, Window[RequestedThemeVariant=Dark] Border.info-icon">
            <Setter Property="Background" Value="{StaticResource QuestionBackgroundDark}"/>
        </Style>
        <Style Selector="Window[RequestedThemeVariant=Dark] TextBlock.question-icon, Window[RequestedThemeVariant=Dark] TextBlock.info-icon">
            <Setter Property="Foreground" Value="{StaticResource QuestionForegroundDark}"/>
        </Style>
        
        <!-- Warning Icon Styles -->
        <Style Selector="Window[RequestedThemeVariant=Light] Border.warning-icon">
            <Setter Property="Background" Value="{StaticResource WarningBackgroundLight}"/>
        </Style>
        <Style Selector="Window[RequestedThemeVariant=Light] TextBlock.warning-icon">
            <Setter Property="Foreground" Value="{StaticResource WarningForegroundLight}"/>
        </Style>
        <Style Selector="Window[RequestedThemeVariant=Dark] Border.warning-icon">
            <Setter Property="Background" Value="{StaticResource WarningBackgroundDark}"/>
        </Style>
        <Style Selector="Window[RequestedThemeVariant=Dark] TextBlock.warning-icon">
            <Setter Property="Foreground" Value="{StaticResource WarningForegroundDark}"/>
        </Style>
    </Window.Styles>

    <StackPanel Margin="20" Spacing="16">
        <StackPanel Orientation="Horizontal" Spacing="12">
            <Border x:Name="IconBorder"
                    CornerRadius="20" 
                    Width="40" 
                    Height="40"
                    VerticalAlignment="Top">
                <Image x:Name="IconDisplay" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <StackPanel Spacing="8" VerticalAlignment="Center">
                <TextBlock x:Name="MessageText"
                           FontSize="{DynamicResource GlobalHeaderFontSize}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap"
                           MaxWidth="400"/>
                <TextBlock x:Name="DetailText"
                           FontSize="{DynamicResource GlobalFontSize}"
                           FontWeight="Medium"
                           TextWrapping="Wrap"
                           MaxWidth="400"
                           IsVisible="False"/>
            </StackPanel>
        </StackPanel>
        
        <StackPanel Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10"
                    Margin="0,8,0,0">
            <Button x:Name="Button1"
                    Click="Button1_Click"
                    Classes="rounded grey"
                    FontSize="{DynamicResource GlobalFontSize}"/>
            <Button x:Name="Button2"
                    Click="Button2_Click"
                    Classes="rounded red"
                    FontSize="{DynamicResource GlobalFontSize}"/>
            <Button x:Name="Button3"
                    Click="Button3_Click"
                    Classes="rounded green"
                    FontSize="{DynamicResource GlobalFontSize}"/>
        </StackPanel>
    </StackPanel>
</Window>