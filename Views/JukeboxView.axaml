<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Gamelist_Manager.ViewModels"
        xmlns:vlc="using:LibVLCSharp.Avalonia"
        mc:Ignorable="d" d:DesignWidth="640" d:DesignHeight="480"
        x:Class="Gamelist_Manager.Views.JukeboxView"
        x:DataType="vm:JukeboxViewModel"
        Title="Jukebox"
        Width="640" Height="480"
        MinWidth="640" MinHeight="480"
        CanResize="True"
        WindowStartupLocation="CenterOwner">

    <Design.DataContext>
        <vm:JukeboxViewModel/>
    </Design.DataContext>

    <Window.Styles>
        <Style Selector="Grid.playing TextBlock">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
        </Style>
    </Window.Styles>

    <Grid>
        <!-- Collapsible Left Sidebar Playlist Overlay (Using Popup) -->
        <Popup IsOpen="{Binding IsPlaylistVisible}" 
               PlacementTarget="{Binding ElementName=LeftAnchor}"
               Placement="RightEdgeAlignedTop"
               VerticalOffset="0">
            <Grid Width="320" Height="{Binding #VideoView.Bounds.Height}" RowDefinitions="Auto, Auto, Auto, *"
                  Background="#B3151515">

                <!-- System Info Header -->
                <StackPanel Grid.Row="0" Margin="10" Spacing="5" HorizontalAlignment="Stretch">
                    <Image Source="{Binding SystemLogo}" MaxHeight="120" Stretch="Uniform" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding Tracks.Count, StringFormat='{}{0} Media Files'}" 
                               HorizontalAlignment="Center" 
                               FontSize="{DynamicResource GlobalFontSize}" 
                               Foreground="{DynamicResource SubtleTextBrush}"/>
                </StackPanel>

                <!-- Search box -->
                <TextBox Grid.Row="1"
                         Text="{Binding SearchText, Mode=TwoWay}"
                         PlaceholderText="Search playlist..."
                         Margin="10,5,10,5"
                         VerticalAlignment="Center"/>

                <!-- Column Headers -->
                <Grid Grid.Row="2" ColumnDefinitions="*, Auto, Auto, Auto" Margin="15,5,15,5">
                    <TextBlock Grid.Column="0" Text="Title" FontSize="{DynamicResource GlobalSmallFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}"/>
                    <TextBlock Grid.Column="1" Text="Length" FontSize="{DynamicResource GlobalSmallFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                    <TextBlock Grid.Column="2" Text="Resolution" IsVisible="{ReflectionBinding $parent[Window].DataContext.HasVideoInPlaylist}" Width="70" FontSize="{DynamicResource GlobalSmallFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                    <TextBlock Grid.Column="3" Text="Bitrate" FontSize="{DynamicResource GlobalSmallFontSize}" FontWeight="SemiBold" Foreground="{DynamicResource SubtleTextBrush}" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                </Grid>

                <!-- Track ListBox -->
                <ListBox Grid.Row="3"
                         ItemsSource="{Binding FilteredTracks}"
                         SelectedItem="{Binding SelectedTrack, Mode=TwoWay}"
                         BorderThickness="0"
                         Background="Transparent"
                         Margin="0,0,0,10">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:JukeboxTrack">
                            <Grid ColumnDefinitions="*, 55, Auto, 60" Background="Transparent" Classes.playing="{Binding IsPlaying}">
                                <!-- Title with playing status indicator -->
                                <DockPanel Grid.Column="0">
                                    <!-- Triangle indicator when playing -->
                                    <Path DockPanel.Dock="Left"
                                          Fill="{DynamicResource AccentTextBrush}"
                                          Data="M 0,0 L 0,10 L 8,5 Z"
                                          Width="8" Height="10"
                                          Margin="0,0,8,0"
                                          VerticalAlignment="Center"
                                          IsVisible="{Binding IsPlaying}" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               TextTrimming="CharacterEllipsis"
                                               FontSize="{DynamicResource GlobalSmallFontSize}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>
                                <!-- Length -->
                                <TextBlock Grid.Column="1" Text="{Binding Duration}" FontSize="{DynamicResource GlobalSmallFontSize}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                <!-- Resolution -->
                                <TextBlock Grid.Column="2" Text="{Binding Resolution}" IsVisible="{ReflectionBinding $parent[Window].DataContext.HasVideoInPlaylist}" Width="70" FontSize="{DynamicResource GlobalSmallFontSize}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                                <!-- Bitrate -->
                                <TextBlock Grid.Column="3" Text="{Binding Bitrate}" FontSize="{DynamicResource GlobalSmallFontSize}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,5,0"/>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Popup>
        
        <!-- Main Video and Player Area -->
        <Grid RowDefinitions="*, 40">
            <!-- Video Container -->
            <vlc:VideoView Grid.Row="0" x:Name="VideoView" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />

            <!-- Anchors for precise Popup placement within the airspace -->
            <Control Grid.Row="0" x:Name="LeftAnchor" Width="0" HorizontalAlignment="Left" VerticalAlignment="Top" />
            <Control Grid.Row="0" x:Name="RightAnchor" Width="0" HorizontalAlignment="Right" VerticalAlignment="Top" />

            <!-- Control Bar -->
            <Border Grid.Row="1" Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="0,1,0,0">
                <Grid ColumnDefinitions="Auto, Auto, *, 120">

                    <!-- Playlist toggle button -->
                    <Button Grid.Column="0"
                            Command="{Binding TogglePlaylistCommand}"
                            ToolTip.Tip="Show File Picker"
                            Margin="5,3,5,3"
                            IsEnabled="{Binding HasMultipleTracks}"
                            Classes="transparentbutton">
                        <Image Source="avares://Gamelist_Manager/Assets/Buttons/glossybutton.png"
                               Width="24" Height="24"/>
                    </Button>

                    <!-- Random checkbox -->
                    <CheckBox Grid.Column="1"
                              Content="Random"
                              IsChecked="{Binding IsRandomPlayback}"
                              VerticalAlignment="Center"
                              Margin="5,0,5,0"
                              IsEnabled="{Binding HasMultipleTracks}"
                              ToolTip.Tip="Randomize Playback" />

                    <!-- Transport buttons -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                        <Button Command="{Binding PreviousCommand}"
                                IsEnabled="{Binding HasMultipleTracks}"
                                Margin="5,3,5,3"
                                Classes="transparentbutton"
                                ToolTip.Tip="Previous">
                            <Image Source="avares://Gamelist_Manager/Assets/Buttons/previous.png"
                                   Width="24" Height="24"/>
                        </Button>

                        <Button Command="{Binding PauseCommand}"
                                IsEnabled="{Binding CanPause}"
                                Margin="0,3,5,3"
                                Classes="transparentbutton"
                                ToolTip.Tip="Pause">
                            <Image Source="avares://Gamelist_Manager/Assets/Buttons/pause.png"
                                   Width="24" Height="24"/>
                        </Button>

                        <Button Command="{Binding StopCommand}"
                                IsEnabled="{Binding CanStop}"
                                Margin="5,3,5,3"
                                Classes="transparentbutton"
                                ToolTip.Tip="Stop">
                            <Image Source="avares://Gamelist_Manager/Assets/Buttons/stop.png"
                                   Width="24" Height="24"/>
                        </Button>

                        <Button Command="{Binding PlayCommand}"
                                IsEnabled="{Binding CanPlay}"
                                Margin="0,3,5,3"
                                Classes="transparentbutton"
                                ToolTip.Tip="Play">
                            <Image Source="avares://Gamelist_Manager/Assets/Buttons/play.png"
                                   Width="24" Height="24"/>
                        </Button>

                        <Button Command="{Binding NextCommand}"
                                IsEnabled="{Binding HasMultipleTracks}"
                                Margin="5,3,5,3"
                                Classes="transparentbutton"
                                ToolTip.Tip="Next">
                            <Image Source="avares://Gamelist_Manager/Assets/Buttons/next.png"
                                   Width="24" Height="24"/>
                        </Button>
                    </StackPanel>

                    <!-- Right side buttons -->
                    <StackPanel Grid.Column="3" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <!-- Volume Slider -->
                        <Slider Minimum="0" Maximum="100" Value="{Binding Volume}"
                                Width="80"
                                Margin="0,0,10,0"
                                ToolTip.Tip="Volume" />
                                
                        <!-- Visualizer toggle button -->
                        <Button Command="{Binding TogglePickerCommand}"
                                IsVisible="{Binding VisualizationsEnabled}"
                                ToolTip.Tip="Show Visualizer Picker"
                                Margin="5,3,5,3"
                                Classes="transparentbutton">
                            <Image Source="avares://Gamelist_Manager/Assets/Icons/visualizer.png" Width="24" Height="24"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Right Sidebar Visualizer Picker Overlay (Using Popup to bypass native HWND Airspace) -->
        <Popup IsOpen="{Binding IsPickerVisible}" 
               PlacementTarget="{Binding ElementName=RightAnchor}"
               Placement="LeftEdgeAlignedTop"
               VerticalOffset="0">
            <Grid Width="350" Height="{Binding #VideoView.Bounds.Height}" RowDefinitions="Auto, *, Auto"
                  Background="#B3151515">

                <!-- Top Header -->
                <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="10">
                    <TextBlock Grid.Column="0" Text="Visualizations" FontWeight="SemiBold" FontSize="{DynamicResource GlobalFontSize}" VerticalAlignment="Center" Foreground="{DynamicResource AccentTextBrush}"/>
                    <Button Grid.Column="1" Content="Random 🎲" Command="{Binding PickRandomPresetCommand}" Classes="transparentbutton" Padding="5,2"/>
                </Grid>

                <!-- Dual Listbox Layout -->
                <Grid Grid.Row="1" ColumnDefinitions="0.4*, 0.6*" Margin="10,0,10,10">
                    
                    <!-- Categories -->
                    <ListBox Grid.Column="0" 
                             ItemsSource="{Binding PresetCategories}" 
                             SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                             Background="Transparent" BorderThickness="0" Margin="0,0,5,0">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PresetCategory">
                                <TextBlock Text="{Binding Name}" FontSize="{DynamicResource GlobalSmallFontSize}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Presets -->
                    <ListBox Grid.Column="1" 
                             ItemsSource="{Binding SelectedCategory.Presets}"
                             SelectedItem="{Binding SelectedPreset, Mode=TwoWay}"
                             Background="#20ffffff" CornerRadius="4" BorderThickness="0"
                             DoubleTapped="PresetList_DoubleTapped">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="vm:PresetItem">
                                <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" FontSize="{DynamicResource GlobalSmallFontSize}"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
                
                <!-- Action Buttons -->
                <StackPanel Grid.Row="2" Margin="10,0,10,10" Spacing="5">
                    <TextBlock Text="Click Apply or double click to apply preset" 
                               FontSize="{DynamicResource GlobalSmallFontSize}" 
                               HorizontalAlignment="Center" 
                               Foreground="{DynamicResource SubtleTextBrush}" 
                               Margin="0,0,0,2"/>
                    <Grid ColumnDefinitions="*, *, *, *">
                        <Button Grid.Column="0" Content="Apply" 
                                Command="{Binding ApplyPresetCommand}" 
                                Classes="rounded green"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0"/>
                        <Button Grid.Column="1" Content="Add Favorite" 
                                Command="{Binding AddToFavoritesCommand}" 
                                Classes="rounded blue"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0"/>
                        <Button Grid.Column="2" Content="Delete Favorite" 
                                Command="{Binding RemoveFromFavoritesCommand}" 
                                Classes="rounded blue"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0"/>
                        <Button Grid.Column="3" Content="Rename" 
                                Command="{Binding RenamePresetCommand}" 
                                Classes="rounded grey"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="2,0"/>
                    </Grid>
                </StackPanel>
            </Grid>
        </Popup>

        <!-- Initializing Message Popup -->
        <Popup IsOpen="{Binding IsInitializing}"
               PlacementTarget="{Binding #VideoView}"
               Placement="Center">
            <Border Background="{DynamicResource PanelBackground}" 
                    BorderBrush="{DynamicResource PanelBorder}"
                    BorderThickness="1"
                    CornerRadius="8" 
                    Padding="20" 
                    HorizontalAlignment="Center" 
                    VerticalAlignment="Center">
                <TextBlock Text="Initializing Player..." 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AccentTextBrush}"/>
            </Border>
        </Popup>
    </Grid>
</Window>
