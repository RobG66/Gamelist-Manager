<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Gamelist_Manager.ViewModels"
             xmlns:views="using:Gamelist_Manager.Views"
             xmlns:controls="using:Gamelist_Manager.Views.Controls"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="400"
             x:Class="Gamelist_Manager.Views.MediaItemView"
             x:DataType="vm:MediaItemViewModel"
             FontSize="{DynamicResource GlobalFontSize}"
             IsVisible="{Binding IsVisible}">

    <UserControl.Styles>
        <Style Selector="TextBlock.MediaHeader">
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentTextBrush}"/>
            <Setter Property="FontSize" Value="{DynamicResource GlobalHeaderFontSize}"/>
        </Style>

        <Style Selector="Border.MediaBorder">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="MinWidth" Value="10"/>
            <Setter Property="MinHeight" Value="10"/>
        </Style>

        <Style Selector="Border.MediaBorder.MediaShadow">
            <Setter Property="Effect">
                <DropShadowEffect Color="Black" OffsetX="5" OffsetY="5" BlurRadius="10" Opacity="0.4"/>
            </Setter>
        </Style>

        <Style Selector="Border.MediaBorder.DragOver">
            <Setter Property="BorderBrush" Value="LimeGreen"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <Style Selector="Image.MediaImage">
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </UserControl.Styles>

    <Border Background="{DynamicResource MediaItemBackground}"
            CornerRadius="8"
            Margin="6"
            Padding="8,6,8,8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="{Binding MediaType}"
                       Classes="MediaHeader"/>

            <Border Grid.Row="1"
                    Name="MediaBorder"
                    Classes="MediaBorder MediaShadow"
                    Classes.DragOver="{Binding IsDragOver}"
                    DragDrop.AllowDrop="True">

                <Panel>
                    <Image Classes="MediaImage"
                           Source="{Binding ImageBitmap}">
                        <Image.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="FileExists"/>
                                <Binding Path="!IsManual"/>
                                <Binding Path="!IsVideo"/>
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>

                    <Image Classes="MediaImage"
                           Source="/Assets/Icons/manual.png"
                           Opacity="0.8">
                        <Image.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="IsManual"/>
                                <Binding Path="FileExists"/>
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>

                    <Image Classes="MediaImage"
                           Source="/Assets/Icons/manual.png"
                           Opacity="0.3">
                        <Image.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="IsManual"/>
                                <Binding Path="!FileExists"/>
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>

                    <Image Classes="MediaImage"
                           Source="/Assets/missing.png"
                           Opacity="0.6">
                        <Image.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="ShowMissingIcon"/>
                                <Binding Path="!IsManual"/>
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>

                    <Image Classes="MediaImage"
                           Source="{DynamicResource DropIconImage}"
                           Opacity="0.4">
                        <Image.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="ShowDropIcon"/>
                                <Binding Path="!IsManual"/>
                                <Binding Path="!IsVideo"/>
                            </MultiBinding>
                        </Image.IsVisible>
                    </Image>

                    <controls:MpvVideoView MediaPlayer="{Binding MediaPlayer}"
                                            HorizontalAlignment="Center"
                                            VerticalAlignment="Center">
                        <controls:MpvVideoView.IsVisible>
                            <MultiBinding Converter="{x:Static BoolConverters.And}">
                                <Binding Path="IsVideo"/>
                                <Binding Path="FileExists"/>
                            </MultiBinding>
                        </controls:MpvVideoView.IsVisible>
                    </controls:MpvVideoView>
                </Panel>
            </Border>

            <views:MediaButtonView Grid.Row="2"
                                   DataContext="{Binding}"
                                   Margin="0,0,0,5"
                                   VerticalAlignment="Bottom"
                                   HorizontalAlignment="Center"/>
        </Grid>
    </Border>

</UserControl>
